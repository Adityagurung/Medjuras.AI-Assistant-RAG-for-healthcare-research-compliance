# MyGenAssist — chat/completions
MYGENASSIST_API_KEY=<your-API-key>
MYGENASSIST_BASE_URL=<your-base-url>
MYGENASSIST_CHAT_MODEL=gpt-oss-120b
MYGENASSIST_AUX_MODEL=gpt-5.1
MYGENASSIST_MAX_TOKENS=8191
MYGENASSIST_JUDGE_MAX_TOKENS=8191
# Streamlit dropdown models
MYGENASSIST_STREAMLIT_OPENAI_MODEL=gpt-oss-120b
MYGENASSIST_STREAMLIT_ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=120

# --- Ollama (optional; Streamlit user can switch to local llama3.2) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Elasticsearch (host: docker-compose maps 9200) ---
ES_URL=http://elasticsearch:9200
ES_LOCAL_URL=http://localhost:9200
ES_INDEX=medical_docs

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_LOCAL_URL=http://localhost:6333
QDRANT_COLLECTION=medjuris

# --- PostgreSQL (Grafana + feedback) ---
POSTGRES_DB=yourdbname
POSTGRES_USER=<yourusername>
POSTGRES_PASSWORD=<yourpwd>
POSTGRES_HOST=localhost
POSTGRES_PORT=5433


# --- Grafana ---
GRAFANA_ADMIN_USER=<yourusername>
GRAFANA_ADMIN_PASSWORD=<yourpassword>
GRAFANA_SECRET_KEY=<yoursecretkey>

# --- PubMed live API (LangGraph agent + tools) ---
ENTREZ_EMAIL=<youremail@something.com>

# --- App ---
SKIP_WARMUP=false
ENVIRONMENT=development
EMBED_DEVICE=cpu
